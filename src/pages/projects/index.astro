---
import { getCollection } from "astro:content";
import { PROJECT_CATEGORIES, getProjectsByCategory } from "@/lib/projects";

import PageLayout from "@/components/layouts/page/layout.astro";
import ProjectsList from "@/components/screens/projects/projects-list.astro";
import Contributions from "@/components/screens/home/contributions.astro";

const projects = await getCollection("projects");
const { professional, openSource, personal } = getProjectsByCategory(projects);
---

<PageLayout
    title="My Projects"
    description="Explore my portfolio of innovative web applications, startup ventures, client solutions, and experimental projects showcasing modern development practices and cutting-edge technologies."
>
    <ProjectsList title={PROJECT_CATEGORIES.professional} projects={professional} />
    <ProjectsList title={PROJECT_CATEGORIES.personal} projects={personal} />
    <ProjectsList title={PROJECT_CATEGORIES.openSource} projects={openSource} />
    <Contributions />
</PageLayout>
